<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Raised Beds — Build It or Buy It</title>
<link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Literata:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --ink:#1A110A; --wood:#9B5C2A; --cedar:#C2762A; --sawdust:#F5E6CC;
  --white:#FDF9F3; --steel:#6B6055; --sage:#6A8C4A; --rust:#B04020;
  --muted:#7A6858; --plank:#EDD9B8;
}
html{scroll-behavior:smooth;}
body{font-family:'Literata',serif;background:var(--white);color:var(--ink);overflow-x:hidden;}

/* ── SIDE NAV ── */
.side-nav{position:fixed;left:1.5rem;top:50%;transform:translateY(-50%);z-index:100;display:flex;flex-direction:column;gap:1rem;}
.side-dot{display:flex;align-items:center;gap:0.7rem;text-decoration:none;}
.side-dot .dot{width:9px;height:9px;border-radius:50%;background:rgba(155,92,42,0.2);border:2px solid var(--wood);transition:all 0.2s;flex-shrink:0;}
.side-dot:hover .dot,.side-dot.active .dot{background:var(--cedar);border-color:var(--cedar);transform:scale(1.3);}
.side-dot .dot-label{font-family:'Space Mono',monospace;font-size:0.56rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--wood);opacity:0;transform:translateX(-6px);transition:all 0.2s;white-space:nowrap;}
.side-dot:hover .dot-label{opacity:1;transform:translateX(0);}

/* ── MOBILE NAV ── */
.top-nav{display:none;position:fixed;top:0;left:0;right:0;z-index:200;background:var(--ink);padding:0 1.2rem;height:52px;align-items:center;justify-content:space-between;}
.top-nav .logo{font-family:'Archivo Black',sans-serif;font-size:0.9rem;color:var(--cedar);letter-spacing:0.03em;}
.nav-toggle{display:flex;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px;}
.nav-toggle span{display:block;width:22px;height:2px;background:var(--sawdust);border-radius:2px;transition:transform 0.22s,opacity 0.22s;}
.nav-toggle.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.nav-toggle.open span:nth-child(2){opacity:0;}
.nav-toggle.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
.mobile-menu{display:none;position:fixed;top:52px;left:0;right:0;z-index:199;background:var(--ink);border-bottom:2px solid var(--cedar);flex-direction:column;max-height:0;overflow:hidden;transition:max-height 0.3s;}
.mobile-menu.open{max-height:80vh;overflow-y:auto;}
.mobile-menu a{display:block;padding:0.9rem 1.2rem;color:var(--sawdust);font-family:'Space Mono',monospace;font-size:0.76rem;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;border-bottom:1px solid rgba(255,255,255,0.06);}
.mobile-menu a:hover{color:var(--cedar);}

/* ── SHARED ── */
.page{max-width:900px;margin:0 auto;padding:0 2.5rem;}
section{padding:5.5rem 0;}
.eyebrow{font-family:'Space Mono',monospace;font-size:0.63rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--cedar);display:block;margin-bottom:0.6rem;}
.big-title{font-family:'Archivo Black',sans-serif;font-size:clamp(2.2rem,5.5vw,4rem);line-height:1.05;color:var(--ink);margin-bottom:1.1rem;}
.big-title em{color:var(--cedar);font-style:normal;}
.intro{font-size:1rem;color:var(--muted);line-height:1.8;max-width:640px;margin-bottom:2.5rem;}
.sub-title{font-family:'Archivo Black',sans-serif;font-size:1.1rem;color:var(--ink);margin:2.5rem 0 1rem;}
.scroll-x{width:100%;overflow-x:auto;-webkit-overflow-scrolling:touch;}
.scroll-x table{min-width:520px;}

/* ── HERO ── */
.hero{min-height:100vh;background:var(--ink);display:flex;flex-direction:column;align-items:flex-start;justify-content:center;padding:4rem 2.5rem 4rem 5rem;position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;right:-60px;top:0;bottom:0;width:55%;background:repeating-linear-gradient(90deg,rgba(155,92,42,0.04) 0px,rgba(155,92,42,0.04) 1px,transparent 1px,transparent 40px),repeating-linear-gradient(0deg,rgba(155,92,42,0.04) 0px,rgba(155,92,42,0.04) 1px,transparent 1px,transparent 40px);}
.hero-tag{font-family:'Space Mono',monospace;font-size:0.63rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--cedar);margin-bottom:1.4rem;}
.hero h1{font-family:'Archivo Black',sans-serif;font-size:clamp(3rem,9vw,7rem);line-height:0.95;color:var(--white);max-width:680px;margin-bottom:2rem;}
.hero h1 span{color:var(--cedar);display:block;}
.hero-sub{color:var(--sawdust);font-size:1rem;line-height:1.75;max-width:460px;margin-bottom:3rem;font-weight:300;}
.hero-cta{display:flex;gap:1rem;flex-wrap:wrap;}
.btn{font-family:'Space Mono',monospace;font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.75rem 1.5rem;border-radius:4px;text-decoration:none;transition:all 0.2s;display:inline-block;}
.btn-primary{background:var(--cedar);color:var(--ink);font-weight:700;}
.btn-primary:hover{background:#d4832f;}
.btn-ghost{border:1.5px solid rgba(255,255,255,0.25);color:var(--sawdust);}
.btn-ghost:hover{border-color:var(--cedar);color:var(--cedar);}
.hero-scroll{position:absolute;right:2.5rem;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;align-items:center;gap:0.5rem;}
.hero-scroll span{font-family:'Space Mono',monospace;font-size:0.56rem;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.3);writing-mode:vertical-rl;}
.hero-scroll svg{opacity:0.3;animation:bob 2s ease-in-out infinite;}
@keyframes bob{0%,100%{transform:translateY(0)}50%{transform:translateY(6px)}}

/* ── WHY RAISED BEDS ── */
#why{background:var(--white);}
.why-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1rem;}
.why-card{background:var(--sawdust);border-radius:8px;padding:1.4rem;border-left:3px solid var(--cedar);}
.why-card h4{font-family:'Archivo Black',sans-serif;font-size:1rem;color:var(--ink);margin-bottom:0.5rem;}
.why-card p{font-size:0.87rem;color:var(--muted);line-height:1.65;}
.compare-table{width:100%;border-collapse:collapse;margin-top:1.5rem;}
.compare-table th{text-align:left;font-family:'Space Mono',monospace;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--steel);padding:0.6rem 0.8rem;border-bottom:2px solid var(--plank);}
.compare-table td{padding:0.75rem 0.8rem;font-size:0.86rem;color:var(--muted);border-bottom:1px solid var(--plank);line-height:1.5;vertical-align:top;}
.compare-table td:first-child{font-family:'Archivo Black',sans-serif;font-size:0.88rem;color:var(--ink);}
.compare-table tr:hover td{background:rgba(245,230,204,0.4);}
.chk-yes{color:var(--sage);font-weight:700;}
.chk-no{color:var(--rust);}
.chk-mid{color:var(--wood);}

/* ── BUILD GUIDE ── */
#build{background:var(--plank);}
.build-meta{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:0.75rem;margin-bottom:2.5rem;}
.meta-chip{background:var(--ink);border-radius:6px;padding:0.9rem 1rem;text-align:center;}
.meta-chip .m-val{font-family:'Archivo Black',sans-serif;font-size:1.1rem;color:var(--cedar);}
.meta-chip .m-key{font-family:'Space Mono',monospace;font-size:0.58rem;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.4);margin-top:0.2rem;}
.build-two-col{display:grid;grid-template-columns:1fr 260px;gap:2.5rem;align-items:start;margin-bottom:2.5rem;}
@media(max-width:720px){.build-two-col{grid-template-columns:1fr;}}
.materials-box{background:var(--ink);border-radius:8px;padding:1.4rem;position:sticky;top:1rem;}
.materials-box h4{font-family:'Space Mono',monospace;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--cedar);margin-bottom:1rem;}
.mat-row{display:flex;justify-content:space-between;align-items:flex-start;padding:0.5rem 0;border-bottom:1px solid rgba(255,255,255,0.07);font-size:0.83rem;}
.mat-row:last-child{border-bottom:none;}
.mat-name{color:var(--sawdust);flex:1;line-height:1.4;}
.mat-qty{font-family:'Space Mono',monospace;font-size:0.73rem;color:var(--cedar);margin-left:0.6rem;white-space:nowrap;}
.tool-list{margin-top:1.2rem;}
.tool-row{display:flex;gap:0.5rem;align-items:center;padding:0.4rem 0;font-size:0.82rem;color:var(--sawdust);}
.tool-row::before{content:'—';color:var(--cedar);font-family:'Space Mono',monospace;font-size:0.7rem;}
.steps{display:flex;flex-direction:column;gap:0.9rem;}
.step{background:var(--white);border-radius:8px;padding:1.5rem 1.7rem;display:grid;grid-template-columns:52px 1fr;gap:1.2rem;align-items:start;border:1.5px solid rgba(155,92,42,0.12);transition:transform 0.2s,box-shadow 0.2s;}
.step:hover{transform:translateX(4px);box-shadow:-4px 0 0 var(--cedar);}
.step-num{font-family:'Archivo Black',sans-serif;font-size:1.9rem;color:var(--cedar);line-height:1;margin-top:0.1rem;}
.step h3{font-family:'Archivo Black',sans-serif;font-size:1rem;color:var(--ink);margin-bottom:0.45rem;}
.step p{font-size:0.87rem;color:var(--muted);line-height:1.65;}
.step .step-tip{margin-top:0.7rem;font-size:0.78rem;font-family:'Space Mono',monospace;color:var(--sage);background:rgba(106,140,74,0.08);border-left:2px solid var(--sage);padding:0.45rem 0.75rem;border-radius:0 4px 4px 0;}
.step .step-warn{margin-top:0.6rem;font-size:0.78rem;font-family:'Space Mono',monospace;color:var(--rust);background:rgba(176,64,32,0.06);border-left:2px solid var(--rust);padding:0.45rem 0.75rem;border-radius:0 4px 4px 0;}
.mistake-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1rem;margin-top:1rem;}
.mistake-card{background:var(--white);border-radius:8px;padding:1.3rem;border-top:3px solid var(--rust);}
.mistake-card h5{font-family:'Archivo Black',sans-serif;font-size:0.9rem;color:var(--rust);margin-bottom:0.4rem;}
.mistake-card p{font-size:0.83rem;color:var(--muted);line-height:1.6;}
.fix-tag{font-family:'Space Mono',monospace;font-size:0.68rem;color:var(--sage);margin-top:0.5rem;display:block;}

/* ── BED TYPES ── */
#types{background:var(--white);}
.type-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.25rem;}
.type-card{border:2px solid var(--plank);border-radius:10px;padding:1.5rem;transition:border-color 0.2s;}
.type-card:hover{border-color:var(--cedar);}
.type-card .type-icon{font-size:2rem;margin-bottom:0.6rem;}
.type-card h4{font-family:'Archivo Black',sans-serif;font-size:1rem;color:var(--ink);margin-bottom:0.4rem;}
.type-card p{font-size:0.86rem;color:var(--muted);line-height:1.6;margin-bottom:0.7rem;}
.type-specs{display:flex;gap:0.6rem;flex-wrap:wrap;}
.tspec{font-family:'Space Mono',monospace;font-size:0.62rem;background:var(--sawdust);color:var(--wood);padding:0.2rem 0.55rem;border-radius:3px;}

/* ── SIZING ── */
#sizes{background:var(--sawdust);}
.size-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:1rem;margin-bottom:2.5rem;}
.size-card{border:2px solid var(--plank);border-radius:8px;overflow:hidden;transition:border-color 0.2s;}
.size-card:hover{border-color:var(--cedar);}
.size-header{background:var(--ink);padding:1rem;text-align:center;}
.size-dims{font-family:'Archivo Black',sans-serif;font-size:1.2rem;color:var(--cedar);}
.size-label{font-family:'Space Mono',monospace;font-size:0.58rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.4);margin-top:0.2rem;}
.size-body{padding:1rem 1.1rem;background:var(--white);}
.size-stat{display:flex;justify-content:space-between;font-size:0.81rem;padding:0.28rem 0;border-bottom:1px solid var(--plank);}
.size-stat:last-child{border-bottom:none;}
.s-key{color:var(--muted);}
.s-val{font-family:'Space Mono',monospace;font-size:0.76rem;color:var(--wood);font-weight:700;}
.depth-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:1rem;}
.depth-card{background:var(--white);border-radius:8px;padding:1.3rem;border-left:3px solid var(--wood);}
.depth-card h4{font-family:'Archivo Black',sans-serif;font-size:0.92rem;color:var(--ink);margin-bottom:0.3rem;display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center;}
.depth-inches{font-family:'Space Mono',monospace;font-size:0.68rem;color:var(--cedar);}
.depth-card p{font-size:0.84rem;color:var(--muted);line-height:1.6;}
.access-note{background:var(--ink);border-radius:8px;padding:1.5rem 1.8rem;margin-top:2rem;display:flex;gap:1.5rem;align-items:flex-start;}
.access-note .an-icon{font-size:1.8rem;flex-shrink:0;}
.access-note h4{font-family:'Archivo Black',sans-serif;color:var(--cedar);font-size:1rem;margin-bottom:0.3rem;}
.access-note p{font-size:0.86rem;color:var(--sawdust);line-height:1.65;}

/* ── SOIL ── */
#soil{background:var(--plank);}
.soil-recipe{background:var(--ink);border-radius:10px;padding:1.8rem;max-width:560px;margin-bottom:2rem;}
.recipe-title{font-family:'Space Mono',monospace;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--cedar);margin-bottom:1.2rem;}
.recipe-bar{margin-bottom:1rem;}
.recipe-bar .rb-label{display:flex;justify-content:space-between;margin-bottom:0.3rem;}
.rb-name{font-size:0.85rem;color:var(--sawdust);}
.rb-pct{font-family:'Space Mono',monospace;font-size:0.75rem;color:var(--cedar);}
.rb-track{height:10px;background:rgba(255,255,255,0.08);border-radius:5px;overflow:hidden;}
.rb-fill{height:100%;border-radius:5px;background:var(--cedar);}
.rb-fill.green{background:var(--sage);}
.rb-fill.gray{background:var(--steel);}
.recipe-note{font-size:0.8rem;color:rgba(255,255,255,0.35);font-family:'Space Mono',monospace;margin-top:0.8rem;line-height:1.6;}
.soil-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1rem;}
.soil-card{background:var(--white);border-radius:8px;padding:1.3rem;border-bottom:3px solid var(--plank);}
.soil-card h4{font-family:'Archivo Black',sans-serif;font-size:0.95rem;color:var(--ink);margin-bottom:0.4rem;}
.soil-card p{font-size:0.85rem;color:var(--muted);line-height:1.6;}
.soil-card .soil-tag{font-family:'Space Mono',monospace;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--cedar);display:block;margin-bottom:0.4rem;}
.fill-methods{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1rem;margin-top:1.5rem;}
.fill-card{background:var(--white);border-radius:8px;padding:1.4rem;}
.fill-card h4{font-family:'Archivo Black',sans-serif;font-size:0.95rem;color:var(--ink);margin-bottom:0.5rem;display:flex;align-items:center;gap:0.5rem;}
.fill-icon{font-size:1.3rem;}
.fill-card p{font-size:0.85rem;color:var(--muted);line-height:1.65;}
.fill-card .fill-cost{font-family:'Space Mono',monospace;font-size:0.7rem;color:var(--sage);margin-top:0.6rem;border-top:1px solid var(--plank);padding-top:0.5rem;}

/* ── WATERING ── */
#water{background:var(--white);}
.water-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1.25rem;}
.water-card{background:var(--sawdust);border-radius:8px;padding:1.4rem;}
.water-card h4{font-family:'Archivo Black',sans-serif;font-size:0.95rem;color:var(--ink);margin-bottom:0.5rem;display:flex;align-items:center;gap:0.5rem;}
.water-card p{font-size:0.86rem;color:var(--muted);line-height:1.65;}
.water-card .w-verdict{font-family:'Space Mono',monospace;font-size:0.68rem;color:var(--cedar);margin-top:0.6rem;border-top:1px solid rgba(155,92,42,0.2);padding-top:0.5rem;}
.drip-steps{display:flex;flex-direction:column;gap:0.7rem;margin-top:1.5rem;}
.drip-step{display:flex;gap:1rem;align-items:flex-start;font-size:0.87rem;color:var(--muted);line-height:1.6;}
.drip-num{font-family:'Archivo Black',sans-serif;font-size:1.2rem;color:var(--cedar);flex-shrink:0;width:28px;}
.season-table{width:100%;border-collapse:collapse;margin-top:1.5rem;}
.season-table th{text-align:left;font-family:'Space Mono',monospace;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--steel);padding:0.6rem 0.8rem;border-bottom:2px solid var(--plank);}
.season-table td{padding:0.7rem 0.8rem;font-size:0.86rem;color:var(--muted);border-bottom:1px solid var(--plank);vertical-align:top;line-height:1.5;}
.season-table td:first-child{font-family:'Archivo Black',sans-serif;font-size:0.88rem;color:var(--ink);}

/* ── MATERIALS ── */
#materials{background:var(--sawdust);}
.mat-table{width:100%;border-collapse:collapse;}
.mat-table th{text-align:left;font-family:'Space Mono',monospace;font-size:0.61rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--steel);padding:0.6rem 0.8rem;border-bottom:2px solid var(--plank);}
.mat-table td{padding:0.8rem 0.8rem;font-size:0.85rem;color:var(--muted);border-bottom:1px solid rgba(155,92,42,0.1);line-height:1.5;vertical-align:top;}
.mat-table td:first-child{font-family:'Archivo Black',sans-serif;font-size:0.88rem;color:var(--ink);}
.mat-table tr:hover td{background:rgba(255,255,255,0.5);}
.safe-yes{color:var(--sage);font-weight:700;}
.safe-no{color:var(--rust);font-weight:700;}
.safe-maybe{color:var(--wood);font-weight:700;}
.pro-con{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:2rem;}
@media(max-width:580px){.pro-con{grid-template-columns:1fr;}}
.pro-box,.con-box{border-radius:8px;padding:1.3rem;}
.pro-box{background:rgba(106,140,74,0.1);border-left:3px solid var(--sage);}
.con-box{background:rgba(176,64,32,0.07);border-left:3px solid var(--rust);}
.pro-box h5,.con-box h5{font-family:'Archivo Black',sans-serif;font-size:0.88rem;margin-bottom:0.7rem;}
.pro-box h5{color:var(--sage);}
.con-box h5{color:var(--rust);}
.pro-box li,.con-box li{font-size:0.84rem;color:var(--muted);line-height:1.6;padding:0.2rem 0 0.2rem 1rem;position:relative;list-style:none;}
.pro-box li::before{content:'✓';position:absolute;left:0;color:var(--sage);font-size:0.75rem;}
.con-box li::before{content:'✗';position:absolute;left:0;color:var(--rust);font-size:0.75rem;}

/* ── BUDGET BUYS ── */
#budget{background:var(--ink);}
#budget .eyebrow{color:var(--cedar);}
#budget .big-title{color:var(--white);}
#budget .big-title em{color:var(--cedar);}
#budget .intro{color:var(--sawdust);}
#budget .sub-title{color:var(--sawdust);}
.budget-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.25rem;}
.budget-card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:1.5rem;transition:border-color 0.2s,transform 0.2s;}
.budget-card:hover{border-color:var(--cedar);transform:translateY(-3px);}
.budget-badge{display:inline-block;font-family:'Space Mono',monospace;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.08em;padding:0.2rem 0.6rem;border-radius:3px;margin-bottom:0.8rem;}
.badge-best{background:rgba(194,118,42,0.25);color:var(--cedar);}
.badge-diy{background:rgba(106,140,74,0.25);color:#a0c070;}
.badge-splurge{background:rgba(107,96,85,0.3);color:#c0b0a0;}
.budget-price{font-family:'Archivo Black',sans-serif;font-size:2rem;color:var(--cedar);line-height:1;margin-bottom:0.3rem;}
.budget-price sup{font-size:1rem;vertical-align:top;margin-top:0.3rem;}
.budget-card h4{font-family:'Literata',serif;font-size:1.05rem;color:var(--white);margin-bottom:0.5rem;}
.budget-card p{font-size:0.84rem;color:var(--sawdust);line-height:1.6;margin-bottom:0.8rem;}
.budget-specs{display:flex;gap:0.6rem;flex-wrap:wrap;margin-bottom:1rem;}
.spec-chip{font-family:'Space Mono',monospace;font-size:0.62rem;color:rgba(255,255,255,0.4);background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:3px;padding:0.2rem 0.5rem;}
.budget-pros{list-style:none;margin-bottom:1rem;}
